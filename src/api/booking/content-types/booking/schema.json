{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking",
    "description": "Booking requests between users for skill exchanges."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "message": {
      "type": "text",
      "required": true
    },
    "scheduledFor": {
      "type": "datetime",
      "required": true
    },
    "durationHours": {
      "type": "integer",
      "default": 1
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "completed", "cancelled", "rejected"],
      "default": "pending"
    },
    "reviewed": {
      "type": "boolean",
      "default": false
    },
    "completionNotes": {
      "type": "text"
    },
    "skill": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::skill.skill",
      "required": true
    },
    "requester": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "provider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    }
  }
}

